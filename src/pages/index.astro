---
import Base from "~/layouts/Base.astro";
import Icon from "~/components/Icon.astro";
import SectionHeader from "~/components/SectionHeader.astro";
import { site, services } from "~/data/site";
import { autoRepairSchema, websiteSchema } from "~/lib/seo";

const topServices = services.filter((s) => ["hu-au", "inspektion", "reparaturen"].includes(s.slug));
const description =
  "H.P. Autoservice Dortmund-Derne - Ihr Kfz-Meisterbetrieb für HU/AU, Inspektion, Bremsen, Reifen und Reparaturen aller Marken. 4,8 Sterne aus 89 Bewertungen. Jetzt Termin sichern.";

const heroImg =
  "https://images.unsplash.com/photo-1486754735734-325b5831c3ad?auto=format&fit=crop&w=2000&q=80";
const teamImg =
  "https://images.unsplash.com/photo-1530046339160-ce3e530c7d2f?auto=format&fit=crop&w=1600&q=80";
---

<Base
  title="Kfz-Meisterbetrieb in Dortmund-Derne"
  description={description}
  jsonLd={[autoRepairSchema(), websiteSchema()]}
>
  <section class="hero">
    <div class="hero-image" style={`background-image: url('${heroImg}')`} aria-hidden="true"></div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="container-x hero-inner">
      <div class="hero-content">
        <span class="badge badge-light">
          <Icon name="award" size={14} />
          Kfz-Meisterbetrieb · Familienbetrieb
        </span>
        <h1 class="h-display hero-title text-shadow-strong">
          Ihre Werkstatt im<br />Herzen von Derne.
        </h1>
        <p class="hero-lead text-shadow-soft">
          Ehrliche Beratung, faire Preise, saubere Arbeit. Zwei Meister, ein eingespieltes Team -
          und das Vertrauen unserer Nachbarn aus Dortmund seit vielen Jahren.
        </p>
        <div class="hero-cta">
          <a href={site.phone.href} class="btn btn-accent">
            <Icon name="phone" size={18} />
            {site.phone.display}
          </a>
          <a href="/kontakt/" class="btn btn-outline-light">
            Termin anfragen
            <Icon name="arrow-right" size={16} />
          </a>
        </div>

        <div class="hero-rating">
          <span class="stars" aria-hidden="true">
            <Icon name="star" size={18} class="star-color" />
            <Icon name="star" size={18} class="star-color" />
            <Icon name="star" size={18} class="star-color" />
            <Icon name="star" size={18} class="star-color" />
            <Icon name="star" size={18} class="star-color" />
          </span>
          <div class="rating-text">
            <strong>{site.rating.value}</strong> aus {site.rating.count} Google-Bewertungen
          </div>
        </div>
      </div>
    </div>

    <div class="hero-info-bar">
      <div class="container-x">
        <div class="info-grid">
          <div class="info-item">
            <Icon name="clock" size={20} />
            <div>
              <div class="info-label">Heute geöffnet</div>
              <div class="info-value">Mo - Fr · 08:00 - 17:00 Uhr</div>
            </div>
          </div>
          <div class="info-item">
            <Icon name="map-pin" size={20} />
            <div>
              <div class="info-label">Standort</div>
              <div class="info-value">Nikolaus-Groß-Straße 21, Dortmund-Derne</div>
            </div>
          </div>
          <div class="info-item">
            <Icon name="award" size={20} />
            <div>
              <div class="info-label">Qualifikation</div>
              <div class="info-value">2 Meister · 2 Mitarbeiter</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-x">
      <SectionHeader
        eyebrow="Unsere Leistungen"
        title="Alles, was Ihr Auto braucht - unter einem Dach."
        text="Von der gesetzlichen Hauptuntersuchung bis zur komplexen Reparatur. Wir betreuen alle gängigen Marken mit der Sorgfalt eines Meisterbetriebs."
      />

      <div class="services-grid reveal">
        {
          topServices.map((s) => (
            <a href={`/leistungen/#${s.slug}`} class="service-card">
              <span class="icon-circle">
                <Icon name={s.icon} size={26} />
              </span>
              <h3>{s.title}</h3>
              <p>{s.description}</p>
              <span class="service-link">
                Mehr erfahren <Icon name="arrow-right" size={14} />
              </span>
            </a>
          ))
        }
      </div>

      <div class="all-services-cta reveal">
        <a href="/leistungen/" class="btn btn-ghost">
          Alle 10 Leistungen ansehen
          <Icon name="arrow-right" size={16} />
        </a>
      </div>
    </div>
  </section>

  <section class="section section-trust">
    <div class="container-x">
      <div class="trust-grid">
        <div class="trust-text reveal">
          <span class="eyebrow">Warum H.P. Autoservice?</span>
          <h2 class="h-section">Vertrauen verdient man sich.<br />Stein für Stein.</h2>
          <p class="lead">
            Wir sind ein echter Familienbetrieb in Dortmund-Derne. Kein Werkstatt-Ketten-Filialleiter,
            der nächstes Jahr woanders sitzt - sondern Menschen, die Sie beim nächsten Einkauf wieder treffen.
            Das prägt, wie wir mit Ihrem Auto umgehen.
          </p>

          <ul class="trust-list">
            <li>
              <span class="icon-circle icon-circle-accent">
                <Icon name="award" size={22} />
              </span>
              <div>
                <h4>Meisterbetrieb</h4>
                <p>Eingetragen bei der HWK Dortmund. Zwei Kfz-Meister, vier Hände am Schraubenschlüssel.</p>
              </div>
            </li>
            <li>
              <span class="icon-circle icon-circle-accent">
                <Icon name="handshake" size={22} />
              </span>
              <div>
                <h4>Ehrliche Beratung</h4>
                <p>Wir reparieren, was nötig ist - nicht, was möglich wäre. Transparente Kostenvoranschläge inklusive.</p>
              </div>
            </li>
            <li>
              <span class="icon-circle icon-circle-accent">
                <Icon name="users" size={22} />
              </span>
              <div>
                <h4>Persönlich erreichbar</h4>
                <p>Sie sprechen direkt mit dem Meister oder unserem Büro - nicht mit einem Callcenter.</p>
              </div>
            </li>
            <li>
              <span class="icon-circle icon-circle-accent">
                <Icon name="euro" size={22} />
              </span>
              <div>
                <h4>Faire Preise</h4>
                <p>Stadtteilpreise statt Innenstadt-Stundensätze. Vorab-Festpreis bei Standardarbeiten möglich.</p>
              </div>
            </li>
          </ul>
        </div>

        <div class="trust-image reveal">
          <img src={teamImg} alt="Mechaniker in der Werkstatt" loading="lazy" width="800" height="900" />
          <div class="trust-badge">
            <div class="trust-badge-num">4,8 ★</div>
            <div class="trust-badge-text">aus {site.rating.count} Google-Bewertungen</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-reviews">
    <div class="container-x">
      <SectionHeader
        eyebrow="Stimmen aus Derne"
        title="Was unsere Kunden sagen."
        text={`Authentische Eindrücke aus ${site.rating.count} Bewertungen. Den Originalkommentaren begegnen Sie auf Google.`}
        align="center"
      />

      <div class="reviews-grid reveal">
        <article class="review-card">
          <span class="stars" aria-hidden="true">
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
          </span>
          <p>
            "Schnelle Terminvergabe, kompetenter Service, faire Preise und schnelle Umsetzung.
            Genau so stelle ich mir eine Werkstatt vor."
          </p>
          <div class="review-author">- Kunde aus Dortmund</div>
        </article>

        <article class="review-card">
          <span class="stars" aria-hidden="true">
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
          </span>
          <p>
            "Sehr nettes Team, super Chef, schnelle Terminvergabe, faire Preise.
            Wir kommen seit Jahren immer wieder gerne hierher."
          </p>
          <div class="review-author">- Stammkunde aus Derne</div>
        </article>

        <article class="review-card">
          <span class="stars" aria-hidden="true">
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
          </span>
          <p>
            "Sehr freundlich und hilfsbereit, Reparaturen werden zügig durchgeführt.
            Ehrliche Beratung - das schätze ich besonders."
          </p>
          <div class="review-author">- Kundin aus Scharnhorst</div>
        </article>
      </div>

      <div class="reviews-cta reveal">
        <a href={site.googleReviewsUrl} class="btn btn-ghost" target="_blank" rel="noopener noreferrer">
          Alle Bewertungen auf Google ansehen
          <Icon name="arrow-right" size={16} />
        </a>
      </div>
    </div>
  </section>

  <section class="section-tight section-map">
    <div class="container-x">
      <div class="map-grid">
        <div class="map-text reveal">
          <span class="eyebrow">So finden Sie uns</span>
          <h2 class="h-section">Mitten in Dortmund-Derne.</h2>
          <p class="lead">
            Acht Kilometer nordöstlich der Innenstadt - im Stadtbezirk Scharnhorst.
            Gut erreichbar über die B236 und mit kostenlosen Parkplätzen direkt vor der Tür.
          </p>

          <ul class="map-list">
            <li>
              <Icon name="map-pin" size={18} />
              <div>
                <strong>Adresse</strong>
                <span>{site.address.street}<br />{site.address.zip} {site.address.city}-{site.address.district}</span>
              </div>
            </li>
            <li>
              <Icon name="phone" size={18} />
              <div>
                <strong>Telefon</strong>
                <a href={site.phone.href}>{site.phone.display}</a>
              </div>
            </li>
            <li>
              <Icon name="clock" size={18} />
              <div>
                <strong>Öffnungszeiten</strong>
                <span>Mo - Fr: 08:00 - 17:00 Uhr<br />Sa & So geschlossen</span>
              </div>
            </li>
          </ul>

          <div class="map-cta">
            <a href={site.googleMapsUrl} class="btn btn-navy" target="_blank" rel="noopener noreferrer">
              In Google Maps öffnen
              <Icon name="arrow-right" size={16} />
            </a>
            <a href="/kontakt/" class="btn btn-ghost">Kontakt & Anfahrt</a>
          </div>
        </div>

        <div class="map-embed reveal">
          <iframe
            src={`https://maps.google.com/maps?q=${encodeURIComponent(`${site.address.street}, ${site.address.zip} ${site.address.city}`)}&t=&z=15&ie=UTF8&iwloc=&output=embed`}
            title="Standort H.P. Autoservice in Dortmund-Derne"
            width="100%"
            height="100%"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container-x">
      <div class="cta-band-inner">
        <div>
          <h2 class="h-section" style="color:#fff">Auto-Termin? Lieber heute als morgen.</h2>
          <p class="cta-band-text">
            Rufen Sie an - wir besprechen kurz, worum es geht, und finden den passenden Slot.
            Kein Warten in der Hotline-Schleife. Versprochen.
          </p>
        </div>
        <div class="cta-band-actions">
          <a href={site.phone.href} class="btn btn-accent">
            <Icon name="phone" size={18} />
            {site.phone.display}
          </a>
          <a href={site.whatsapp.href} class="btn btn-outline-light" target="_blank" rel="noopener noreferrer">
            <Icon name="whatsapp" size={18} />
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    min-height: clamp(560px, 78vh, 760px);
    display: flex;
    flex-direction: column;
    color: #fff;
    overflow: hidden;
  }
  .hero-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    transform: scale(1.05);
    z-index: 0;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(18, 40, 68, 0.55) 0%, rgba(18, 40, 68, 0.75) 60%, rgba(18, 40, 68, 0.92) 100%),
      linear-gradient(105deg, rgba(18, 40, 68, 0.85) 0%, rgba(18, 40, 68, 0.5) 55%, rgba(18, 40, 68, 0.3) 100%);
    z-index: 1;
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    align-items: center;
    padding-block: 4.5rem 8rem;
  }
  @media (min-width: 768px) {
    .hero-inner {
      padding-block: 5rem 8rem;
    }
  }

  .hero-content {
    max-width: 38rem;
  }

  .hero-title {
    color: #fff;
    margin: 1.25rem 0 1.5rem;
  }

  .hero-lead {
    color: rgba(255, 255, 255, 0.92);
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.6;
    margin-bottom: 2rem;
    max-width: 36rem;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .hero-rating {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 0.7rem 1.1rem;
    border-radius: 999px;
  }
  .hero-rating .stars {
    display: inline-flex;
    gap: 0.1rem;
  }
  .hero-rating .rating-text {
    color: #fff;
    font-size: 0.92rem;
  }
  .hero-rating strong {
    font-weight: 700;
  }

  .hero-info-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 3;
    background: rgba(248, 247, 244, 0.97);
    backdrop-filter: blur(8px);
    border-top: 1px solid var(--color-line);
    padding-block: 1.1rem;
  }
  .info-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .info-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }
  .info-item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    color: var(--color-ink);
  }
  .info-item :global(svg) {
    color: var(--color-accent);
    flex-shrink: 0;
  }
  .info-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .info-value {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-navy);
    line-height: 1.3;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 700px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .service-card {
    display: block;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: 1rem;
    padding: 2rem;
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow: var(--shadow-soft);
    height: 100%;
  }
  .service-card:hover {
    border-color: var(--color-navy);
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(27, 58, 95, 0.1);
  }
  .service-card h3 {
    font-size: 1.4rem;
    margin: 1.1rem 0 0.5rem;
    color: var(--color-navy);
  }
  .service-card p {
    color: var(--color-ink-soft);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }
  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.92rem;
  }

  .all-services-cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  .section-trust {
    background: linear-gradient(180deg, var(--color-paper) 0%, var(--color-paper-alt) 100%);
  }
  .trust-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 1000px) {
    .trust-grid {
      grid-template-columns: 1.1fr 1fr;
      gap: 4.5rem;
    }
  }

  .trust-list {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .trust-list li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .trust-list h4 {
    font-size: 1.1rem;
    margin-bottom: 0.3rem;
    color: var(--color-navy);
  }
  .trust-list p {
    color: var(--color-ink-soft);
    line-height: 1.55;
    font-size: 0.95rem;
  }

  .trust-image {
    position: relative;
    border-radius: 1.25rem;
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }
  .trust-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .trust-badge {
    position: absolute;
    bottom: 1.25rem;
    left: 1.25rem;
    background: #fff;
    padding: 0.85rem 1.1rem;
    border-radius: 0.75rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }
  .trust-badge-num {
    font-weight: 800;
    font-size: 1.4rem;
    color: var(--color-navy);
    line-height: 1;
  }
  .trust-badge-text {
    font-size: 0.78rem;
    color: var(--color-ink-soft);
    margin-top: 0.2rem;
  }

  .section-reviews {
    background: var(--color-paper);
  }
  .reviews-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 800px) {
    .reviews-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .review-card {
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: var(--shadow-soft);
  }
  .review-card .stars {
    display: inline-flex;
    gap: 0.1rem;
    margin-bottom: 1rem;
  }
  .review-card p {
    color: var(--color-ink);
    font-style: italic;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }
  .review-author {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-ink-soft);
  }

  .reviews-cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  .section-map {
    background: var(--color-paper-alt);
  }
  .map-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: stretch;
  }
  @media (min-width: 900px) {
    .map-grid {
      grid-template-columns: 1fr 1.1fr;
      gap: 3rem;
    }
  }
  .map-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .map-list li {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
  }
  .map-list :global(svg) {
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 0.2rem;
  }
  .map-list strong {
    display: block;
    font-weight: 700;
    color: var(--color-navy);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.15rem;
  }
  .map-list span,
  .map-list a {
    color: var(--color-ink);
    line-height: 1.5;
  }
  .map-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  .map-embed {
    border-radius: 1rem;
    overflow: hidden;
    min-height: 380px;
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-line);
  }
  .map-embed iframe {
    display: block;
    height: 100%;
    min-height: 380px;
  }

  .cta-band {
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-navy-deep) 100%);
    color: #fff;
    padding-block: 4rem;
    position: relative;
    overflow: hidden;
  }
  .cta-band::before {
    content: "";
    position: absolute;
    top: -100px;
    right: -100px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(184, 148, 95, 0.15), transparent 70%);
    z-index: 0;
  }
  .cta-band-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }
  @media (min-width: 800px) {
    .cta-band-inner {
      grid-template-columns: 1.4fr auto;
    }
  }
  .cta-band-text {
    color: rgba(255, 255, 255, 0.85);
    margin-top: 0.85rem;
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 48ch;
  }
  .cta-band-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
