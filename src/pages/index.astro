---
import Base from "~/layouts/Base.astro";
import Icon from "~/components/Icon.astro";
import SectionHeader from "~/components/SectionHeader.astro";
import { site, services } from "~/data/site";
import { autoRepairSchema, websiteSchema } from "~/lib/seo";

const topServices = services.filter((s) => ["hu-au", "inspektion", "reparaturen"].includes(s.slug));
const description =
  "H.P. Autoservice Dortmund-Derne - Ihr Kfz-Meisterbetrieb für HU/AU, Inspektion, Bremsen, Reifen und Reparaturen aller Marken. 4,8 Sterne aus 89 Bewertungen. Jetzt Termin sichern.";

const heroImg =
  "https://images.unsplash.com/photo-1486006920555-c77dcf18193c?auto=format&fit=crop&w=2000&q=80";
const teamImg =
  "https://images.unsplash.com/photo-1487754180451-c456f719a1fc?auto=format&fit=crop&w=1600&q=80";

const trustPoints = [
  "Familiengeführter Meisterbetrieb",
  "TÜV- & DEKRA-Partner direkt vor Ort",
  "Ehrliche Festpreis-Kostenvoranschläge",
  "Reparaturen aller Marken & Modelle",
];
---

<Base
  title="Kfz-Meisterbetrieb in Dortmund-Derne"
  description={description}
  jsonLd={[autoRepairSchema(), websiteSchema()]}
>
  <section class="hero">
    <div class="hero-image" style={`background-image: url('${heroImg}')`} aria-hidden="true"></div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="container-x hero-inner">
      <div class="hero-grid">
        <div class="hero-content">
          <span class="badge badge-light">
            <Icon name="award" size={14} />
            Kfz-Meisterbetrieb seit Jahren
          </span>
          <h1 class="h-display hero-title text-shadow-strong">
            Ihre Werkstatt im<br />Herzen von Derne.
          </h1>
          <p class="hero-lead text-shadow-soft">
            Ehrliche Beratung, faire Preise, saubere Arbeit. Zwei Meister, ein eingespieltes Team -
            und das Vertrauen unserer Nachbarn aus Dortmund seit vielen Jahren.
          </p>

          <ul class="trust-checks">
            {
              trustPoints.map((p) => (
                <li>
                  <span class="check-icon" aria-hidden="true">
                    <Icon name="check" size={14} />
                  </span>
                  <span>{p}</span>
                </li>
              ))
            }
          </ul>

          <div class="hero-cta">
            <a href={site.phone.href} class="btn btn-accent">
              <Icon name="phone" size={18} />
              {site.phone.display}
            </a>
            <a href="/kontakt/" class="btn btn-outline-light">
              Termin anfragen
              <Icon name="arrow-right" size={16} />
            </a>
          </div>
        </div>

        <aside class="hero-aside" aria-label="Google-Bewertungen">
          <div class="review-card-hero">
            <div class="review-card-top">
              <div class="google-mark" aria-hidden="true">
                <svg viewBox="0 0 48 48" width="22" height="22"><path fill="#FFC107" d="M43.6 20.1H42V20H24v8h11.3c-1.6 4.7-6.1 8-11.3 8-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.1 8 3l5.7-5.7C33.6 6.1 29 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.6-.4-3.9z"/><path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 16 19 13 24 13c3.1 0 5.8 1.1 8 3l5.7-5.7C33.6 6.1 29 4 24 4 16.3 4 9.7 8.3 6.3 14.7z"/><path fill="#4CAF50" d="M24 44c5 0 9.5-1.9 12.9-5l-6-5.1C29 35.5 26.6 36.4 24 36.4c-5.2 0-9.6-3.3-11.2-8l-6.5 5C9.5 39.6 16.2 44 24 44z"/><path fill="#1976D2" d="M43.6 20.1H42V20H24v8h11.3c-.8 2.3-2.2 4.2-4.1 5.6l6 5.1c-.4.4 6.4-4.7 6.4-14.7 0-1.3-.1-2.6-.4-3.9z"/></svg>
              </div>
              <div class="review-card-meta">
                <strong>Google-Bewertungen</strong>
                <span>{site.rating.count} Rezensionen</span>
              </div>
            </div>

            <div class="review-card-rating">
              <span class="rating-num">{site.rating.value.toString().replace(".", ",")}</span>
              <div class="stars" aria-hidden="true">
                <Icon name="star" size={20} class="star-color" />
                <Icon name="star" size={20} class="star-color" />
                <Icon name="star" size={20} class="star-color" />
                <Icon name="star" size={20} class="star-color" />
                <Icon name="star" size={20} class="star-color" />
              </div>
              <span class="rating-of">von 5 Sternen</span>
            </div>

            <blockquote class="review-quote">
              "Schnelle Terminvergabe, kompetenter Service, faire Preise."
            </blockquote>

            <a
              href={site.googleReviewsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="review-link"
            >
              Alle Bewertungen lesen
              <Icon name="arrow-right" size={14} />
            </a>
          </div>
        </aside>
      </div>
    </div>

    <div class="hero-info-bar">
      <div class="container-x">
        <div class="info-grid">
          <div class="info-item">
            <Icon name="clock" size={20} />
            <div>
              <div class="info-label">Heute geöffnet</div>
              <div class="info-value">Mo - Fr · 08:00 - 17:00 Uhr</div>
            </div>
          </div>
          <div class="info-item">
            <Icon name="map-pin" size={20} />
            <div>
              <div class="info-label">Standort</div>
              <div class="info-value">Nikolaus-Groß-Straße 21, Dortmund-Derne</div>
            </div>
          </div>
          <div class="info-item">
            <Icon name="award" size={20} />
            <div>
              <div class="info-label">Qualifikation</div>
              <div class="info-value">2 Meister · 2 Mitarbeiter</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-x">
      <SectionHeader
        eyebrow="Unsere Leistungen"
        title="Alles, was Ihr Auto braucht - unter einem Dach."
        text="Von der gesetzlichen Hauptuntersuchung bis zur komplexen Reparatur. Wir betreuen alle gängigen Marken mit der Sorgfalt eines Meisterbetriebs."
      />

      <div class="services-grid reveal">
        {
          topServices.map((s) => (
            <a href={`/leistungen/#${s.slug}`} class="service-card">
              <span class="icon-circle">
                <Icon name={s.icon} size={26} />
              </span>
              <h3>{s.title}</h3>
              <p>{s.description}</p>
              <span class="service-link">
                Mehr erfahren <Icon name="arrow-right" size={14} />
              </span>
            </a>
          ))
        }
      </div>

      <div class="all-services-cta reveal">
        <a href="/leistungen/" class="btn btn-ghost">
          Alle 10 Leistungen ansehen
          <Icon name="arrow-right" size={16} />
        </a>
      </div>
    </div>
  </section>

  <section class="section section-trust">
    <div class="container-x">
      <div class="trust-grid">
        <div class="trust-text reveal">
          <span class="eyebrow">Warum H.P. Autoservice?</span>
          <h2 class="h-section">Vertrauen verdient man sich.<br />Stein für Stein.</h2>
          <p class="lead">
            Wir sind ein echter Familienbetrieb in Dortmund-Derne. Kein Werkstatt-Ketten-Filialleiter,
            der nächstes Jahr woanders sitzt - sondern Menschen, die Sie beim nächsten Einkauf wieder treffen.
            Das prägt, wie wir mit Ihrem Auto umgehen.
          </p>

          <ul class="trust-list">
            <li>
              <span class="icon-circle icon-circle-accent">
                <Icon name="award" size={22} />
              </span>
              <div>
                <h4>Meisterbetrieb</h4>
                <p>Eingetragen bei der HWK Dortmund. Zwei Kfz-Meister, vier Hände am Schraubenschlüssel.</p>
              </div>
            </li>
            <li>
              <span class="icon-circle icon-circle-accent">
                <Icon name="handshake" size={22} />
              </span>
              <div>
                <h4>Ehrliche Beratung</h4>
                <p>Wir reparieren, was nötig ist - nicht, was möglich wäre. Transparente Kostenvoranschläge inklusive.</p>
              </div>
            </li>
            <li>
              <span class="icon-circle icon-circle-accent">
                <Icon name="users" size={22} />
              </span>
              <div>
                <h4>Persönlich erreichbar</h4>
                <p>Sie sprechen direkt mit dem Meister oder unserem Büro - nicht mit einem Callcenter.</p>
              </div>
            </li>
            <li>
              <span class="icon-circle icon-circle-accent">
                <Icon name="euro" size={22} />
              </span>
              <div>
                <h4>Faire Preise</h4>
                <p>Stadtteilpreise statt Innenstadt-Stundensätze. Vorab-Festpreis bei Standardarbeiten möglich.</p>
              </div>
            </li>
          </ul>
        </div>

        <div class="trust-image reveal">
          <img src={teamImg} alt="Mechaniker in der Werkstatt" loading="lazy" width="800" height="900" />
          <div class="trust-badge">
            <div class="trust-badge-num">4,8 ★</div>
            <div class="trust-badge-text">aus {site.rating.count} Google-Bewertungen</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-reviews">
    <div class="container-x">
      <SectionHeader
        eyebrow="Stimmen aus Derne"
        title="Was unsere Kunden sagen."
        text={`Authentische Eindrücke aus ${site.rating.count} Bewertungen. Den Originalkommentaren begegnen Sie auf Google.`}
        align="center"
      />

      <div class="reviews-grid reveal">
        <article class="review-card">
          <span class="stars" aria-hidden="true">
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
          </span>
          <p>
            "Schnelle Terminvergabe, kompetenter Service, faire Preise und schnelle Umsetzung.
            Genau so stelle ich mir eine Werkstatt vor."
          </p>
          <div class="review-author">- Kunde aus Dortmund</div>
        </article>

        <article class="review-card">
          <span class="stars" aria-hidden="true">
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
          </span>
          <p>
            "Sehr nettes Team, super Chef, schnelle Terminvergabe, faire Preise.
            Wir kommen seit Jahren immer wieder gerne hierher."
          </p>
          <div class="review-author">- Stammkunde aus Derne</div>
        </article>

        <article class="review-card">
          <span class="stars" aria-hidden="true">
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
          </span>
          <p>
            "Sehr freundlich und hilfsbereit, Reparaturen werden zügig durchgeführt.
            Ehrliche Beratung - das schätze ich besonders."
          </p>
          <div class="review-author">- Kundin aus Scharnhorst</div>
        </article>
      </div>

      <div class="reviews-cta reveal">
        <a href={site.googleReviewsUrl} class="btn btn-ghost" target="_blank" rel="noopener noreferrer">
          Alle Bewertungen auf Google ansehen
          <Icon name="arrow-right" size={16} />
        </a>
      </div>
    </div>
  </section>

  <section class="section-tight section-map">
    <div class="container-x">
      <div class="map-grid">
        <div class="map-text reveal">
          <span class="eyebrow">So finden Sie uns</span>
          <h2 class="h-section">Mitten in Dortmund-Derne.</h2>
          <p class="lead">
            Acht Kilometer nordöstlich der Innenstadt - im Stadtbezirk Scharnhorst.
            Gut erreichbar über die B236 und mit kostenlosen Parkplätzen direkt vor der Tür.
          </p>

          <ul class="map-list">
            <li>
              <Icon name="map-pin" size={18} />
              <div>
                <strong>Adresse</strong>
                <span>{site.address.street}<br />{site.address.zip} {site.address.city}-{site.address.district}</span>
              </div>
            </li>
            <li>
              <Icon name="phone" size={18} />
              <div>
                <strong>Telefon</strong>
                <a href={site.phone.href}>{site.phone.display}</a>
              </div>
            </li>
            <li>
              <Icon name="clock" size={18} />
              <div>
                <strong>Öffnungszeiten</strong>
                <span>Mo - Fr: 08:00 - 17:00 Uhr<br />Sa & So geschlossen</span>
              </div>
            </li>
          </ul>

          <div class="map-cta">
            <a href={site.googleMapsUrl} class="btn btn-navy" target="_blank" rel="noopener noreferrer">
              In Google Maps öffnen
              <Icon name="arrow-right" size={16} />
            </a>
            <a href="/kontakt/" class="btn btn-ghost">Kontakt & Anfahrt</a>
          </div>
        </div>

        <div class="map-embed reveal">
          <iframe
            src={`https://maps.google.com/maps?q=${encodeURIComponent(`${site.address.street}, ${site.address.zip} ${site.address.city}`)}&t=&z=15&ie=UTF8&iwloc=&output=embed`}
            title="Standort H.P. Autoservice in Dortmund-Derne"
            width="100%"
            height="100%"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container-x">
      <div class="cta-band-inner">
        <div>
          <h2 class="h-section" style="color:#fff">Auto-Termin? Lieber heute als morgen.</h2>
          <p class="cta-band-text">
            Rufen Sie an - wir besprechen kurz, worum es geht, und finden den passenden Slot.
            Kein Warten in der Hotline-Schleife. Versprochen.
          </p>
        </div>
        <div class="cta-band-actions">
          <a href={site.phone.href} class="btn btn-accent">
            <Icon name="phone" size={18} />
            {site.phone.display}
          </a>
          <a href={site.whatsapp.href} class="btn btn-outline-light" target="_blank" rel="noopener noreferrer">
            <Icon name="whatsapp" size={18} />
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    min-height: clamp(620px, 86vh, 820px);
    display: flex;
    flex-direction: column;
    color: #fff;
    overflow: hidden;
  }
  .hero-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    transform: scale(1.05);
    z-index: 0;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.78) 60%, rgba(0, 0, 0, 0.95) 100%),
      linear-gradient(95deg, rgba(0, 0, 0, 0.92) 0%, rgba(0, 0, 0, 0.65) 50%, rgba(0, 0, 0, 0.4) 100%);
    z-index: 1;
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    align-items: center;
    padding-block: 3.5rem 9rem;
    width: 100%;
  }
  @media (min-width: 768px) {
    .hero-inner {
      padding-block: 4.5rem 9.5rem;
    }
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
    width: 100%;
  }
  @media (min-width: 1000px) {
    .hero-grid {
      grid-template-columns: 1.35fr 1fr;
      gap: 3.5rem;
      align-items: center;
    }
  }

  .hero-content {
    text-align: left;
    max-width: 38rem;
  }

  .hero-title {
    color: #fff;
    margin: 1.25rem 0 1.25rem;
  }

  .hero-lead {
    color: rgba(255, 255, 255, 0.92);
    font-size: clamp(1.02rem, 1.3vw, 1.18rem);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    max-width: 36rem;
  }

  .trust-checks {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.55rem;
  }
  @media (min-width: 480px) {
    .trust-checks {
      grid-template-columns: 1fr 1fr;
      gap: 0.55rem 1.25rem;
    }
  }
  .trust-checks li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: rgba(255, 255, 255, 0.95);
    font-size: 0.93rem;
    font-weight: 500;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
  }
  .check-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 999px;
    background: var(--color-yellow);
    color: var(--color-black);
    flex-shrink: 0;
    box-shadow: 0 2px 6px rgba(254, 196, 32, 0.5);
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero-aside {
    display: flex;
    justify-content: flex-start;
  }
  @media (min-width: 1000px) {
    .hero-aside {
      justify-content: flex-end;
    }
  }

  .review-card-hero {
    background: rgba(255, 255, 255, 0.97);
    color: var(--color-ink);
    border-radius: 1rem;
    padding: 1.5rem 1.6rem;
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(8px);
    width: 100%;
    max-width: 22rem;
    border: 1px solid rgba(255, 255, 255, 0.4);
  }
  @media (min-width: 1000px) {
    .review-card-hero {
      max-width: 24rem;
    }
  }

  .review-card-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-line);
  }
  .google-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: #fff;
    border-radius: 999px;
    border: 1px solid var(--color-line);
    flex-shrink: 0;
  }
  .review-card-meta {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
  }
  .review-card-meta strong {
    color: var(--color-black);
    font-size: 0.95rem;
    font-weight: 700;
  }
  .review-card-meta span {
    color: var(--color-ink-soft);
    font-size: 0.8rem;
  }

  .review-card-rating {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: 1rem 0 0.85rem;
    flex-wrap: wrap;
  }
  .rating-num {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--color-black);
    line-height: 1;
  }
  .review-card-rating .stars {
    display: inline-flex;
    gap: 0.1rem;
  }
  .rating-of {
    width: 100%;
    color: var(--color-ink-soft);
    font-size: 0.82rem;
    font-weight: 500;
  }

  .review-quote {
    margin: 0 0 1rem;
    padding: 0.75rem 0.9rem;
    background: var(--color-paper-alt);
    border-left: 3px solid var(--color-yellow);
    border-radius: 0.5rem;
    color: var(--color-ink);
    font-style: italic;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .review-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--color-black);
    font-weight: 700;
    font-size: 0.88rem;
    text-decoration: none;
    border-bottom: 2px solid var(--color-yellow);
    padding-bottom: 2px;
  }
  .review-link:hover {
    color: var(--color-black);
    border-bottom-color: var(--color-yellow-hover);
  }

  .hero-info-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 3;
    background: rgba(248, 247, 244, 0.97);
    backdrop-filter: blur(8px);
    border-top: 1px solid var(--color-line);
    padding-block: 1rem;
  }
  .info-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }
  @media (min-width: 768px) {
    .info-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }
  .info-item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    color: var(--color-ink);
  }
  .info-item :global(svg) {
    color: var(--color-black);
    background: var(--color-yellow);
    border-radius: 999px;
    padding: 0.4rem;
    box-sizing: content-box;
    flex-shrink: 0;
  }
  .info-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .info-value {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-black);
    line-height: 1.3;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 700px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .service-card {
    display: block;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: 1rem;
    padding: 1.5rem;
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow: var(--shadow-soft);
    height: 100%;
  }
  @media (min-width: 700px) {
    .service-card { padding: 2rem; }
  }
  .service-card:hover {
