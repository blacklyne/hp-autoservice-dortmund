---
import Base from "~/layouts/Base.astro";
import Icon from "~/components/Icon.astro";
import PageHero from "~/components/PageHero.astro";
import { site } from "~/data/site";
import { breadcrumbSchema } from "~/lib/seo";

const description =
  "Kontakt zu H.P. Autoservice in Dortmund-Derne. Telefon 0231 810717, Adresse Nikolaus-Groß-Straße 21, Öffnungszeiten Mo-Fr 8-17 Uhr. Termin direkt anfragen.";

const breadcrumbs = breadcrumbSchema([
  { name: "Start", url: "/" },
  { name: "Kontakt", url: "/kontakt/" },
]);

const heroImg =
  "https://images.unsplash.com/photo-1530046339160-ce3e530c7d2f?auto=format&fit=crop&w=2000&q=80";
---

<Base title="Kontakt" description={description} jsonLd={breadcrumbs}>
  <PageHero
    eyebrow="Termin & Kontakt"
    title="Wir freuen uns auf Ihren Anruf."
    text="Am schnellsten geht es per Telefon. Schriftlich gerne per Formular oder E-Mail - wir melden uns zeitnah zurück."
    image={heroImg}
  />

  <section class="section">
    <div class="container-x">
      <div class="contact-grid">
        <div class="contact-info reveal">
          <h2 class="h-section">Direkter Draht zur Werkstatt.</h2>

          <div class="contact-cards">
            <a href={site.phone.href} class="contact-card highlight">
              <span class="icon-circle icon-circle-accent">
                <Icon name="phone" size={26} />
              </span>
              <div>
                <div class="contact-label">Anrufen (am schnellsten)</div>
                <div class="contact-value">{site.phone.display}</div>
                <div class="contact-meta">Mo - Fr · 08:00 - 17:00 Uhr</div>
              </div>
            </a>

            <a href={`mailto:${site.email}`} class="contact-card">
              <span class="icon-circle">
                <Icon name="mail" size={24} />
              </span>
              <div>
                <div class="contact-label">E-Mail</div>
                <div class="contact-value">{site.email}</div>
                <div class="contact-meta">Antwort spätestens am nächsten Werktag</div>
              </div>
            </a>

            <div class="contact-card">
              <span class="icon-circle">
                <Icon name="map-pin" size={24} />
              </span>
              <div>
                <div class="contact-label">Adresse</div>
                <div class="contact-value">{site.address.street}</div>
                <div class="contact-meta">{site.address.zip} {site.address.city}-{site.address.district}</div>
              </div>
            </div>

            <div class="contact-card">
              <span class="icon-circle">
                <Icon name="clock" size={24} />
              </span>
              <div>
                <div class="contact-label">Öffnungszeiten</div>
                <div class="contact-value">Mo - Fr · 08:00 - 17:00</div>
                <div class="contact-meta">Samstag & Sonntag geschlossen</div>
              </div>
            </div>
          </div>
        </div>

        <div class="contact-form-wrap reveal">
          <div class="form-card">
            <h2 class="h-section">Termin online anfragen.</h2>
            <p class="lead">
              Schreiben Sie kurz, worum es geht - wir melden uns am nächsten Werktag mit
              einem passenden Termin zurück.
            </p>

            <form
              class="contact-form"
              action={`https://formspree.io/f/${site.formspreeId}`}
              method="POST"
            >
              <div class="form-row">
                <label class="field">
                  <span>Name *</span>
                  <input type="text" name="name" required autocomplete="name" />
                </label>
                <label class="field">
                  <span>Telefon *</span>
                  <input type="tel" name="phone" required autocomplete="tel" />
                </label>
              </div>

              <label class="field">
                <span>E-Mail</span>
                <input type="email" name="email" autocomplete="email" />
              </label>

              <label class="field">
                <span>Fahrzeug (Marke, Modell, Baujahr)</span>
                <input type="text" name="fahrzeug" placeholder="z.B. VW Golf 7, 2018" />
              </label>

              <label class="field">
                <span>Was können wir für Sie tun? *</span>
                <textarea name="anliegen" rows="5" required placeholder="HU/AU? Bremsen? Klimaanlage? Beschreiben Sie kurz Ihr Anliegen."></textarea>
              </label>

              <label class="checkbox">
                <input type="checkbox" name="datenschutz" required />
                <span>
                  Ich habe die <a href="/datenschutz/">Datenschutzerklärung</a> gelesen und bin
                  mit der Verarbeitung meiner Daten einverstanden.
                </span>
              </label>

              <button type="submit" class="btn btn-accent submit-btn">
                Anfrage senden
                <Icon name="arrow-right" size={16} />
              </button>

              <p class="form-note">
                Lieber direkt anrufen?
                <a href={site.phone.href}>{site.phone.display}</a>
              </p>
            </form>
          </div>
        </div>
      </div>

      <div class="map-section reveal">
        <h2 class="h-section">So finden Sie uns.</h2>
        <div class="map-frame">
          <iframe
            src={`https://maps.google.com/maps?q=${encodeURIComponent(`${site.address.street}, ${site.address.zip} ${site.address.city}`)}&t=&z=16&ie=UTF8&iwloc=&output=embed`}
            title="Standort H.P. Autoservice Dortmund-Derne auf Google Maps"
            width="100%"
            height="500"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        <div class="map-hint">
          <Icon name="map-pin" size={18} />
          <span>Kostenlose Parkplätze direkt vor der Werkstatt.</span>
          <a href={site.googleMapsUrl} target="_blank" rel="noopener noreferrer" class="map-link">
            Route in Google Maps planen
            <Icon name="arrow-right" size={14} />
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 1000px) {
    .contact-grid {
      grid-template-columns: 1fr 1.1fr;
      gap: 4rem;
      align-items: start;
    }
  }

  .contact-info .h-section {
    margin-bottom: 2rem;
    color: #fff;
  }

  .contact-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-card {
    display: flex;
    gap: 1.1rem;
    align-items: center;
    background: var(--color-card);
    border: 1px solid var(--color-line);
    border-radius: 0.85rem;
    padding: 1.25rem 1.4rem;
    text-decoration: none;
    transition: all 0.15s ease;
    color: var(--color-text);
  }
  a.contact-card:hover {
    border-color: var(--color-yellow);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(254, 196, 32, 0.12);
  }
  .contact-card.highlight {
    background: var(--color-yellow);
    border-color: var(--color-yellow);
    color: #1A1A1A;
  }
  .contact-card.highlight :global(.icon-circle) {
    background: #1A1A1A;
    color: var(--color-yellow);
    border-color: #1A1A1A;
  }
  .contact-card.highlight .contact-label,
  .contact-card.highlight .contact-meta {
    color: rgba(0, 0, 0, 0.7);
  }
  .contact-card.highlight .contact-value {
    color: #0A0A0A;
  }
  .contact-label {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.2rem;
  }
  .contact-value {
    font-weight: 700;
    color: #fff;
    font-size: 1.05rem;
    line-height: 1.3;
  }
  .contact-meta {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: 0.15rem;
  }

  .form-card {
    background: var(--color-light);
    border: 1px solid var(--color-light-line);
    border-radius: 1.25rem;
    padding: 1.5rem;
    box-shadow: var(--shadow-card);
    color: var(--color-ink);
  }
  @media (min-width: 600px) {
    .form-card { padding: 2.5rem; }
  }
  .form-card .h-section { color: var(--color-ink); }
  .form-card .lead {
    margin-bottom: 1.75rem;
    color: var(--color-ink-soft);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 600px) {
    .form-row {
      grid-template-columns: 1fr 1fr;
    }
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .field span {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-ink);
  }
  .field input,
  .field textarea {
    width: 100%;
    padding: 0.75rem 0.95rem;
    border: 1.5px solid var(--color-light-line);
    border-radius: 0.55rem;
    font-family: inherit;
    font-size: 1rem;
    color: var(--color-ink);
    background: #fff;
    transition: border 0.15s ease, box-shadow 0.15s ease;
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-yellow);
    box-shadow: 0 0 0 3px rgba(254, 196, 32, 0.25);
  }
  .field textarea {
    resize: vertical;
    min-height: 110px;
  }

  .checkbox {
    display: flex;
    gap: 0.65rem;
    align-items: flex-start;
    font-size: 0.88rem;
    color: var(--color-ink-soft);
    line-height: 1.5;
    margin-top: 0.3rem;
  }
  .checkbox input {
    margin-top: 0.25rem;
    accent-color: var(--color-yellow);
  }
  .checkbox a {
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-color: var(--color-yellow);
    text-decoration-thickness: 2px;
    text-underline-offset: 2px;
  }

  .submit-btn {
    margin-top: 0.75rem;
    align-self: flex-start;
  }

  .form-note {
    font-size: 0.88rem;
    color: var(--color-ink-soft);
    margin-top: 0.5rem;
    text-align: center;
  }
  .form-note a {
    color: var(--color-ink);
    font-weight: 700;
    margin-left: 0.3rem;
    border-bottom: 2px solid var(--color-yellow);
  }

  .map-section {
    margin-top: 5rem;
  }
  .map-section .h-section {
    margin-bottom: 1.5rem;
    color: #fff;
  }
  .map-frame {
    border-radius: 1rem;
    overflow: hidden;
    border: 2px solid var(--color-yellow);
    box-shadow: var(--shadow-card);
  }
  .map-frame iframe {
    display: block;
  }
  .map-hint {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem;
    margin-top: 1.25rem;
    color: var(--color-text-soft);
    font-size: 0.92rem;
  }
  .map-hint :global(svg) {
    color: var(--color-yellow);
  }
  .map-link {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--color-yellow);
    font-weight: 700;
  }
</style>
