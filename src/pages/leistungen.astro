---
import Base from "~/layouts/Base.astro";
import Icon from "~/components/Icon.astro";
import PageHero from "~/components/PageHero.astro";
import { site, services } from "~/data/site";
import { breadcrumbSchema } from "~/lib/seo";

const description =
  "Alle Leistungen von H.P. Autoservice in Dortmund-Derne: HU/AU, Inspektion, Bremsen, Reifen, Klimaanlage, Diagnose, Achsvermessung, Reparaturen und Unfallinstandsetzung.";

const breadcrumbs = breadcrumbSchema([
  { name: "Start", url: "/" },
  { name: "Leistungen", url: "/leistungen/" },
]);

const heroImg =
  "https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&w=2000&q=80";
---

<Base
  title="Leistungen"
  description={description}
  jsonLd={breadcrumbs}
>
  <PageHero
    eyebrow="Was wir können"
    title="Werkstatt-Leistungen unter einem Dach."
    text="Vom routinemäßigen Ölwechsel bis zur kompletten Unfallinstandsetzung. Alles aus Meisterhand - für alle gängigen Marken."
    image={heroImg}
  />

  <section class="section">
    <div class="container-x">
      <div class="services-list">
        {
          services.map((s, i) => (
            <article id={s.slug} class={`service-row reveal ${i % 2 === 1 ? "alt" : ""}`}>
              <div class="service-row-icon">
                <span class="icon-circle">
                  <Icon name={s.icon} size={32} />
                </span>
              </div>
              <div class="service-row-text">
                <h2>{s.title}</h2>
                <p class="service-short">{s.short}</p>
                <p>{s.description}</p>
              </div>
              <div class="service-row-cta">
                <a href={site.phone.href} class="btn btn-ghost">
                  <Icon name="phone" size={16} />
                  Termin
                </a>
              </div>
            </article>
          ))
        }
      </div>

      <div class="leistungen-cta reveal">
        <h2 class="h-section">Ihre Leistung nicht dabei?</h2>
        <p class="lead" style="margin-inline:auto">
          Wir können mehr, als hier steht - rufen Sie uns einfach an. Eine ehrliche
          Einschätzung gibt es bei uns immer kostenlos.
        </p>
        <div class="leistungen-cta-actions">
          <a href={site.phone.href} class="btn btn-accent">
            <Icon name="phone" size={18} />
            {site.phone.display}
          </a>
          <a href="/kontakt/" class="btn btn-ghost">Kontaktformular</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .services-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .service-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    align-items: start;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: 1rem;
    padding: 1.5rem;
    transition: all 0.2s ease;
    box-shadow: var(--shadow-soft);
    scroll-margin-top: 6rem;
  }
  .service-row:hover {
    border-color: var(--color-navy);
    box-shadow: 0 8px 24px rgba(27, 58, 95, 0.08);
  }
  @media (min-width: 800px) {
    .service-row {
      grid-template-columns: auto 1fr auto;
      gap: 2rem;
      padding: 2.25rem 2.5rem;
      align-items: center;
    }
  }
  .service-row.alt {
    background: var(--color-paper-alt);
  }

  .service-row-text h2 {
    font-size: 1.5rem;
    margin-bottom: 0.4rem;
    color: var(--color-navy);
  }
  .service-short {
    display: inline-block;
    color: var(--color-black);
    background: var(--color-yellow);
    padding: 0.2rem 0.6rem;
    border-radius: 0.3rem;
    font-weight: 700;
    font-size: 0.85rem;
    margin-bottom: 0.7rem;
  }
  .service-row-text p:last-child {
    color: var(--color-ink-soft);
    line-height: 1.6;
  }

  .service-row-cta {
    margin-top: 1rem;
  }
  @media (min-width: 800px) {
    .service-row-cta {
      margin-top: 0;
    }
  }

  .leistungen-cta {
    margin-top: 5rem;
    padding: 3rem 2rem;
    background: linear-gradient(135deg, var(--color-paper-alt), var(--color-paper));
    border: 1px solid var(--color-line);
    border-radius: 1.25rem;
    text-align: center;
  }
  .leistungen-cta .h-section {
    margin-bottom: 1rem;
  }
  .leistungen-cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1.75rem;
  }
</style>
