---
import { site, nav } from "~/data/site";
import Icon from "./Icon.astro";

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container-x">
    <div class="footer-grid">
      <div class="footer-col">
        <div class="footer-brand">
          <span class="footer-mark">H.P.</span>
          <div>
            <div class="footer-name">Autoservice</div>
            <div class="footer-sub">Kfz-Meisterbetrieb Dortmund-Derne</div>
          </div>
        </div>
        <p class="footer-text">
          Ihr Familien-Meisterbetrieb in Dortmund-Derne. Ehrliche Beratung, faire Preise, saubere Arbeit -
          seit Jahren das Vertrauen unserer Nachbarn.
        </p>
        <div class="rating">
          <span class="stars" aria-hidden="true">
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
            <Icon name="star" size={16} class="star-color" />
          </span>
          <span class="rating-text">{site.rating.value} aus {site.rating.count} Bewertungen</span>
        </div>
      </div>

      <div class="footer-col">
        <h4 class="footer-title">Kontakt</h4>
        <ul class="footer-list">
          <li>
            <Icon name="map-pin" size={16} />
            <span>
              {site.address.street}<br />
              {site.address.zip} {site.address.city}-{site.address.district}
            </span>
          </li>
          <li>
            <Icon name="phone" size={16} />
            <a href={site.phone.href}>{site.phone.display}</a>
          </li>
          <li>
            <Icon name="mail" size={16} />
            <a href={`mailto:${site.email}`}>{site.email}</a>
          </li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-title">Öffnungszeiten</h4>
        <ul class="footer-list">
          <li>
            <Icon name="clock" size={16} />
            <span>Mo - Fr<br />08:00 - 17:00 Uhr</span>
          </li>
          <li class="closed">
            <Icon name="clock" size={16} />
            <span>Sa & So<br />geschlossen</span>
          </li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-title">Schnellzugriff</h4>
        <ul class="footer-nav">
          {nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
          <li><a href="/impressum/">Impressum</a></li>
          <li><a href="/datenschutz/">Datenschutz</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} {site.name}. Alle Rechte vorbehalten.</p>
      <p class="footer-meta">Kfz-Meisterbetrieb · Eingetragen bei der Handwerkskammer Dortmund</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-black-deep);
    color: rgba(255, 255, 255, 0.85);
    padding-top: 4rem;
    padding-bottom: 1.5rem;
    margin-top: 4rem;
    border-top: 4px solid var(--color-yellow);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }
  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
      gap: 3rem;
    }
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 1rem;
  }
  .footer-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.55rem;
    background: var(--color-yellow);
    color: var(--color-black);
    font-weight: 800;
    font-size: 0.85rem;
    flex-shrink: 0;
  }
  .footer-name {
    font-weight: 800;
    color: #fff;
    font-size: 1.1rem;
    line-height: 1.1;
  }
  .footer-sub {
    font-size: 0.78rem;
    color: var(--color-yellow);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 700;
    line-height: 1.1;
    margin-top: 0.15rem;
  }

  .footer-text {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.92rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
    max-width: 32ch;
  }

  .rating {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
  }
  .stars {
    display: inline-flex;
    gap: 0.05rem;
  }
  .rating-text {
    font-size: 0.82rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
  }

  .footer-title {
    color: #fff;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.25rem;
  }

  .footer-list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-list li {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.92rem;
    line-height: 1.5;
  }
  .footer-list li :global(svg) {
    color: var(--color-yellow);
    flex-shrink: 0;
    margin-top: 0.15rem;
  }
  .footer-list a {
    color: rgba(255, 255, 255, 0.75);
    transition: color 0.15s ease;
  }
  .footer-list a:hover {
    color: #fff;
  }
  .footer-list .closed :global(svg) {
    opacity: 0.5;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-nav a {
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.92rem;
    transition: color 0.15s ease;
  }
  .footer-nav a:hover {
    color: var(--color-yellow);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    align-items: flex-start;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.82rem;
  }
  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
  .footer-meta {
    color: rgba(255, 255, 255, 0.45);
  }
</style>
