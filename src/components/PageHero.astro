---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  image?: string;
}
const {
  eyebrow,
  title,
  text,
  image = "https://images.unsplash.com/photo-1580273916550-e323be2ae537?auto=format&fit=crop&w=2000&q=80",
} = Astro.props;
---

<section class="page-hero">
  <div class="hero-image" style={`background-image: url('${image}')`} aria-hidden="true"></div>
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="container-x hero-inner">
    {eyebrow && <span class="badge badge-light">{eyebrow}</span>}
    <h1 class="h-display text-shadow-strong">{title}</h1>
    {text && <p class="hero-text text-shadow-soft">{text}</p>}
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    color: #fff;
    overflow: hidden;
    min-height: clamp(360px, 48vh, 460px);
    display: flex;
    align-items: center;
  }
  .hero-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: 0;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(18, 40, 68, 0.65) 0%, rgba(18, 40, 68, 0.85) 100%),
      linear-gradient(105deg, rgba(18, 40, 68, 0.85) 0%, rgba(18, 40, 68, 0.45) 100%);
    z-index: 1;
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    padding-block: 4rem;
    max-width: 60rem;
  }
  .hero-inner h1 {
    color: #fff;
    margin-top: 1.25rem;
  }
  .hero-text {
    color: rgba(255, 255, 255, 0.92);
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.6;
    margin-top: 1.25rem;
    max-width: 50rem;
  }
</style>
