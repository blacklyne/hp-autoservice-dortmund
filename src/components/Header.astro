---
import { site, nav } from "~/data/site";
import Icon from "./Icon.astro";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="site-header" id="site-header">
  <div class="container-x">
    <div class="header-inner">
      <a href="/" class="brand" aria-label={`${site.name} - Startseite`}>
        <span class="brand-mark">H.P.</span>
        <span class="brand-text">
          <span class="brand-name">Autoservice</span>
          <span class="brand-sub">Kfz-Meisterbetrieb</span>
        </span>
      </a>

      <nav class="nav-desktop" aria-label="Hauptnavigation">
        {
          nav.map((item) => {
            const itemPath = item.href.replace(/\/$/, "") || "/";
            const isActive = itemPath === path;
            return (
              <a href={item.href} class={isActive ? "nav-link active" : "nav-link"}>
                {item.label}
              </a>
            );
          })
        }
      </nav>

      <a href={site.phone.href} class="phone-cta">
        <Icon name="phone" size={18} />
        <span>{site.phone.display}</span>
      </a>

      <button class="menu-toggle" aria-label="Menü öffnen" aria-expanded="false" id="menu-toggle">
        <Icon name="menu" size={26} />
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden>
    <nav aria-label="Mobile Navigation">
      {
        nav.map((item) => {
          const itemPath = item.href.replace(/\/$/, "") || "/";
          const isActive = itemPath === path;
          return (
            <a href={item.href} class={isActive ? "mobile-link active" : "mobile-link"}>
              {item.label}
            </a>
          );
        })
      }
      <a href={site.phone.href} class="btn btn-accent mobile-cta">
        <Icon name="phone" size={18} />
        Jetzt anrufen
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(248, 247, 244, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-line);
    transition: box-shadow 0.2s ease;
  }
  .site-header.scrolled {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 4.75rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
  }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.55rem;
    background: var(--color-black);
    color: var(--color-yellow);
    font-weight: 800;
    font-size: 0.85rem;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }
  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .brand-name {
    font-weight: 800;
    font-size: 1.05rem;
    color: var(--color-black);
    letter-spacing: -0.01em;
  }
  .brand-sub {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-black-soft);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .nav-desktop {
    display: none;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
  }
  @media (min-width: 1024px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-link {
    padding: 0.5rem 0.95rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-ink);
    transition: color 0.15s ease, background 0.15s ease;
  }
  .nav-link:hover {
    color: var(--color-black);
    background: var(--color-paper-alt);
  }
  .nav-link.active {
    color: var(--color-black);
    background: var(--color-yellow);
  }

  .phone-cta {
    display: none;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-yellow);
    color: var(--color-black);
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.65rem 1.1rem;
    border-radius: 0.5rem;
    margin-left: 0.5rem;
    transition: all 0.15s ease;
    text-decoration: none;
    border: 1.5px solid var(--color-yellow);
  }
  .phone-cta:hover {
    background: var(--color-yellow-hover);
    border-color: var(--color-yellow-hover);
    color: var(--color-black);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(254, 196, 32, 0.4);
  }
  @media (min-width: 768px) {
    .phone-cta {
      display: inline-flex;
    }
  }

  .menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.5rem;
    background: transparent;
    color: var(--color-black);
    border: 1px solid var(--color-line);
    cursor: pointer;
    margin-left: auto;
  }
  @media (min-width: 1024px) {
    .menu-toggle {
      display: none;
    }
  }

  .mobile-menu {
    display: none;
    border-top: 1px solid var(--color-line);
    padding: 1rem 1.25rem 1.5rem;
    background: var(--color-paper);
  }
  .mobile-menu[hidden] {
    display: none;
  }
  .mobile-menu.is-open {
    display: block;
  }

  .mobile-menu nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .mobile-link {
    display: block;
    padding: 0.85rem 1rem;
    border-radius: 0.5rem;
    font-weight: 600;
    color: var(--color-ink);
    text-decoration: none;
    border: 1px solid transparent;
  }
  .mobile-link:hover {
    background: var(--color-paper-alt);
    color: var(--color-black);
  }
  .mobile-link.active {
    background: var(--color-yellow);
    color: var(--color-black);
  }
  .mobile-cta {
    margin-top: 0.5rem;
    width: 100%;
  }
</style>

<script>
  const header = document.getElementById("site-header");
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  if (header) {
    const onScroll = () => {
      if (window.scrollY > 8) header.classList.add("scrolled");
      else header.classList.remove("scrolled");
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const open = menu.classList.toggle("is-open");
      if (open) menu.removeAttribute("hidden");
      else menu.setAttribute("hidden", "");
      toggle.setAttribute("aria-expanded", String(open));
    });
  }
</script>
