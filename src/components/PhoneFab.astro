---
import { site } from "~/data/site";
import Icon from "./Icon.astro";
---

<a href={site.phone.href} class="phone-fab" aria-label="Anrufen">
  <Icon name="phone" size={22} />
</a>

<style>
  .phone-fab {
    position: fixed;
    right: 1.1rem;
    bottom: 1.1rem;
    z-index: 40;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 999px;
    background: var(--color-accent);
    color: #fff;
    box-shadow: 0 6px 20px rgba(200, 48, 44, 0.45), 0 2px 6px rgba(0, 0, 0, 0.15);
    transition: transform 0.2s ease, background 0.2s ease;
    animation: pulse 2.5s infinite;
  }
  .phone-fab:hover {
    background: var(--color-accent-hover);
    color: #fff;
    transform: scale(1.06);
  }

  @media (min-width: 768px) {
    .phone-fab {
      display: none;
    }
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 6px 20px rgba(200, 48, 44, 0.45), 0 0 0 0 rgba(200, 48, 44, 0.4); }
    70% { box-shadow: 0 6px 20px rgba(200, 48, 44, 0.45), 0 0 0 16px rgba(200, 48, 44, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .phone-fab { animation: none; }
  }
</style>
