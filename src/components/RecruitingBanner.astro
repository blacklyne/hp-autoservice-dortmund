---
import Icon from "./Icon.astro";
import { site } from "~/data/site";
---

<aside class="recruiting" aria-label="Stellenangebot">
  <div class="container-x recruiting-inner">
    <span class="recruiting-badge">
      <Icon name="wrench" size={16} />
      Wir stellen ein
    </span>
    <div class="recruiting-text">
      <strong>Kfz-Mechatroniker (m/w/d) gesucht.</strong>
      <span>Familienbetrieb, faire Bezahlung, geregelte Arbeitszeiten - Adrian freut sich auf deinen Anruf.</span>
    </div>
    <a href={site.phone.href} class="recruiting-cta">
      <Icon name="phone" size={16} />
      {site.phone.display}
    </a>
  </div>
</aside>

<style>
  .recruiting {
    background: var(--color-yellow);
    color: #0A0A0A;
    border-block: 1px solid rgba(0, 0, 0, 0.15);
  }

  .recruiting-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    padding-block: 0.85rem;
  }
  @media (min-width: 768px) {
    .recruiting-inner {
      flex-direction: row;
      align-items: center;
      gap: 1.5rem;
      padding-block: 0.7rem;
    }
  }

  .recruiting-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: #0A0A0A;
    color: var(--color-yellow);
    font-weight: 700;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.35rem 0.75rem;
    border-radius: 0.4rem;
    flex-shrink: 0;
  }

  .recruiting-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    flex: 1;
    line-height: 1.35;
  }
  .recruiting-text strong {
    font-weight: 800;
    font-size: 0.98rem;
    color: #0A0A0A;
  }
  .recruiting-text span {
    font-size: 0.88rem;
    color: rgba(0, 0, 0, 0.78);
  }
  @media (min-width: 768px) {
    .recruiting-text {
      flex-direction: row;
      align-items: baseline;
      gap: 0.6rem;
    }
  }

  .recruiting-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: #0A0A0A;
    color: var(--color-yellow);
    font-weight: 700;
    font-size: 0.92rem;
    padding: 0.55rem 0.95rem;
    border-radius: 0.45rem;
    text-decoration: none;
    transition: transform 0.15s ease;
    flex-shrink: 0;
  }
  .recruiting-cta:hover {
    transform: translateY(-1px);
    color: var(--color-yellow);
  }
</style>
